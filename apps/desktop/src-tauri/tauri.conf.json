{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Orchestrator",
  "version": "0.1.0-alpha",
  "identifier": "com.dreaminmaster.local-ai-orchestrator",
  "build": {
    "beforeDevCommand": "./src-tauri/run_dev_backend.sh",
    "devUrl": "http://127.0.0.1:8422",
    "beforeBuildCommand": "",
    "frontendDist": "../../../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Local AI Orchestrator",
        "width": 1440,
        "height": 1000,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["bin/local-ai-orchestrator-backend"],
    "resources": ["bin/local-ai-orchestrator-backend-dir/"]
  }
}
