# ============================================================
# Local AI Self-Supervised Orchestrator — Configuration
# ============================================================

# --- Local LLM Provider ---
# Options: lmstudio, ollama, openai_compatible
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=local-model
LLM_API_KEY=lm-studio

# --- External AI API Keys (optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# --- Server ---
HOST=0.0.0.0
PORT=8422

# --- Security ---
# Max auto-execution loops before requiring user confirmation
MAX_AUTO_LOOPS=20
# Max consecutive failures before stopping
MAX_CONSECUTIVE_FAILURES=5
# Risk level that requires user confirmation: low, medium, high, critical
CONFIRM_RISK_LEVEL=high

# --- Evidence ---
EVIDENCE_DIR=./evidence
SCREENSHOT_DIR=./evidence/screenshots

# --- Database ---
DATABASE_PATH=./storage/orchestrator.db
